{
  "name": "klinok",
  "private": true,
  "version": "0.8.1",
  "type": "module",
  "workspaces": [
    "auth-node",
    "p2p-node",
    "packages/*"
  ],
  "scripts": {
    "release:bump": "node scripts/bump-version.mjs",
    "predev": "npm run build:protocol",
    "dev": "vite --host 127.0.0.1",
    "build:protocol": "npm run build --workspace @klinok/protocol",
    "build:auth": "npm run build --workspace @klinok/auth-node",
    "build:p2p": "npm run build --workspace @klinok/p2p-node",
    "build:ui": "npm run build:protocol && vue-tsc --noEmit && vite build",
    "build": "npm run build:ui && npm run build:auth && npm run build:p2p",
    "preview": "vite preview --host 127.0.0.1",
    "p2p:node": "npm run start --workspace @klinok/p2p-node",
    "auth:node": "npm run start --workspace @klinok/auth-node",
    "auth:provision": "npm run provision --workspace @klinok/auth-node",
    "pretest": "npm run build:protocol",
    "test": "vitest run --run && npm test --workspace @klinok/protocol && npm test --workspace @klinok/auth-node",
    "lint": "eslint . --ext .vue,.ts,.js,.jsx,.cjs,.mjs --fix",
    "lint:check": "eslint . --ext .vue,.ts,.js,.jsx,.cjs,.mjs",
    "precoverage": "npm run build:protocol",
    "coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:compose": "sh scripts/compose-smoke.sh"
  },
  "dependencies": {
    "@chainsafe/libp2p-noise": "^17.0.0",
    "@chainsafe/libp2p-yamux": "^8.0.1",
    "@fontsource/montserrat": "^5.2.8",
    "@helia/bitswap": "^4.0.5",
    "@helia/http": "^4.0.4",
    "@helia/libp2p": "^1.0.5",
    "@ipld/dag-cbor": "^10.0.1",
    "@ipld/dag-json": "^11.0.0",
    "@klinok/protocol": "*",
    "@libp2p/bootstrap": "^12.0.25",
    "@libp2p/gossipsub": "^16.0.3",
    "@libp2p/identify": "^4.1.8",
    "@libp2p/mdns": "^12.0.25",
    "@libp2p/websockets": "^10.1.15",
    "@multiformats/multiaddr": "^13.0.3",
    "@orbitdb/core": "^4.0.0",
    "blockstore-idb": "^4.0.1",
    "blockstore-level": "^4.0.1",
    "datastore-idb": "^5.0.1",
    "events": "^3.3.0",
    "helia": "^7.0.5",
    "libp2p": "^3.3.4",
    "multiformats": "^14.0.4",
    "vue": "^3.5.16",
    "vue-router": "^4.6.4"
  },
  "overrides": {
    "glob": "^13.0.6"
  },
  "allowScripts": {
    "classic-level@3.0.0": true,
    "esbuild@0.28.1": true,
    "argon2@0.44.0": true
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "@playwright/test": "^1.55.0",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^9.33.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^28.1.0",
    "typescript": "^5.8.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^2.2.10"
  }
}
